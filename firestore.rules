rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isModerator() { return signedIn() && userDoc().data.role in ['moderator', 'admin', 'super_admin']; }
    function isAdmin() { return signedIn() && userDoc().data.role in ['admin', 'super_admin']; }
    function isSuperAdmin() { return signedIn() && userDoc().data.role == 'super_admin'; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isModerator());
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'active';
      allow update: if signedIn() && (
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'lastLogin'])
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status)
        || (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status'])
          && (!(resource.data.role == 'super_admin' || request.resource.data.role == 'super_admin') || isSuperAdmin()))
        || (isModerator()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvedActions', 'impactScore']))
      );
      allow delete: if false;
    }

    match /impact_records/{id} {
      allow read: if (resource.data.status == 'approved' && resource.data.visibility in ['anonymous_public', 'public_profile'])
                  || (signedIn() && resource.data.userId == request.auth.uid)
                  || isModerator();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.visibility in ['private', 'anonymous_public', 'public_profile'];
      allow update: if isModerator();
      allow delete: if false;
    }

    match /audit_logs/{id} {
      allow read: if isModerator();
      allow create: if isModerator() || (signedIn() && request.resource.data.actorId == request.auth.uid);
      allow update, delete: if false;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
