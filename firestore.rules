rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isModerator() { return signedIn() && userDoc().data.role in ['moderator', 'admin', 'super_admin']; }
    function isAdmin() { return signedIn() && userDoc().data.role in ['admin', 'super_admin']; }
    function isSuperAdmin() { return signedIn() && userDoc().data.role == 'super_admin'; }
    function validAlias(value) { return value is string && value.size() >= 3 && value.size() <= 20 && value.matches('^[a-z0-9_]+$'); }
    function validAvatar(value) { return value in ['seed', 'leaf', 'tree', 'oasis', 'bridge', 'hands', 'heart', 'book', 'water', 'shield']; }
    function protectedUserFieldsUnchanged(uid) {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isModerator());
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'active'
        && (!('aliasNormalized' in request.resource.data) || validAlias(request.resource.data.aliasNormalized))
        && (!('avatarId' in request.resource.data) || validAvatar(request.resource.data.avatarId));
      allow update: if signedIn() && (
        (request.auth.uid == uid
          && protectedUserFieldsUnchanged(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'displayName',
            'avatarId',
            'avatarUrl',
            'alias',
            'aliasNormalized',
            'realNameVisible',
            'impactPassportEnabled',
            'hideContributionCategories',
            'growthStage',
            'updatedAt',
            'lastLogin',
            'lastLoginServer',
            'emailVerified'
          ])
          && (!('aliasNormalized' in request.resource.data) || validAlias(request.resource.data.aliasNormalized))
          && (!('avatarId' in request.resource.data) || validAvatar(request.resource.data.avatarId)))
        || (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status'])
          && (!(resource.data.role == 'super_admin' || request.resource.data.role == 'super_admin') || isSuperAdmin()))
        || (isModerator()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvedActions', 'impactScore', 'impactCredits', 'trustScore', 'trustRiskScore', 'verificationPenalty', 'riskFlags', 'growthStage']))
      );
      allow delete: if isSuperAdmin() && request.auth.uid != uid;
    }

    match /aliases/{alias} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validAlias(alias)
        && request.resource.data.keys().hasOnly(['uid', 'alias', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.alias == alias;
      allow update: if signedIn()
        && validAlias(alias)
        && resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'alias', 'updatedAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.alias == alias;
      allow delete: if (signedIn()
        && validAlias(alias)
        && resource.data.uid == request.auth.uid)
        || isSuperAdmin();
    }

    match /impact_records/{id} {
      allow read: if (resource.data.status == 'approved' && resource.data.visibility in ['anonymous_public', 'public_profile'])
                  || (signedIn() && resource.data.userId == request.auth.uid)
                  || isModerator();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.visibility in ['private', 'anonymous_public', 'public_profile'];
      allow update: if isModerator();
      allow delete: if isSuperAdmin();
    }

    match /impact_verifications/{id} {
      allow read: if isModerator() || (signedIn() && (resource.data.impactOwnerId == request.auth.uid || resource.data.verifierId == request.auth.uid));
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.weight == 0
        && request.resource.data.penalty == 0;
      allow update: if signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.verifierId == request.auth.uid
        && request.resource.data.impactOwnerId != request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    match /audit_logs/{id} {
      allow read: if isModerator();
      allow create: if isModerator() || (signedIn() && request.resource.data.actorId == request.auth.uid);
      allow update, delete: if false;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
